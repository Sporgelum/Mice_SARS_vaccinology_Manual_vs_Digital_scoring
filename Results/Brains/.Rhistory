library("VennDiagram")
venn.plot <- venn.diagram(
x = list("Old Resection GO:BP" = amp_goids_old,
"Updated Resection GO:BP" = amp_goids_new),
filename = "GO_BP_overlap_vennResection.png",
fill = c("skyblue", "orange"),
alpha = 0.5,
cex = 1.5,
cat.cex = 1.2,
cat.pos = c(-20, 20)
)
venn.plot <- venn.diagram(
x = list("Old Resection GO:BP" = amp_goids_old,
"Updated Resection GO:BP" = amp_goids_new),
filename = NULL,
fill = c("skyblue", "orange"),
alpha = 0.5,
cex = 1.5,
cat.cex = 1.2,
cat.pos = c(-20, 20)
)
library("gridExtra")
grid.newpage()       # ensure a fresh plotting page
grid.draw(venn.plot)
