perc_overlap_old <- round(count_overlap / count_old * 100, 2)
perc_overlap_new <- round(count_overlap / count_new * 100, 2)
perc_overlap_union <- round(count_overlap / length(union(amp_goids_old, amp_goids_new)) * 100, 2)
# Summary tampe
summary_tampe <- data.frame(
Category = c("Old total", "New total", "Overlap", "Unique to old", "Unique to new"),
Count = c(count_old, count_new, count_overlap, count_unique_old, count_unique_new),
Percent = c(100, 100, perc_overlap_union, 100 - perc_overlap_old, 100 - perc_overlap_new)
)
print(summary_tampe)
write.csv(summary_tampe, "GO_BP_overlap_summary.csv", row.names = FALSE)
