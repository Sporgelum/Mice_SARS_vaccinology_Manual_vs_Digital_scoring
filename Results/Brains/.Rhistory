setwd("/Users/emari/OneDrive - Universitaet Bern/ZF_meta-analysis_correction/github_graphml_comparisons/core_folder/")
core <- read_graph(file = "/Users/emari/OneDrive - Universitaet Bern/ZF_meta-analysis_correction/github_graphml_comparisons/heart_regeneration_core_mm_fil_cleaned_Abl_Sham__gobp.graphml" ,format = "graphml")
core
core_goids_old <- vertex.attributes(core)$name
length(core_goids_old)
core_new <- read_graph(file = "/Users/emari/OneDrive - Universitaet Bern/ZF_meta-analysis_correction/Platform/CoreRegeneration/Results/shinny_core_all_clusters.graphml",format = "graphml")
core_new
core_goids_new <- vertex.attributes(core_new)$name
length(core_goids_new)
# Overlap
overlap_ids <- intersect(core_goids_old, core_goids_new)
# Unique to old
unique_old <- setdiff(core_goids_old, core_goids_new)
# Unique to new
unique_new <- setdiff(core_goids_new, core_goids_old)
write.table(overlap_ids, "overlap_ids.txt", row.names = FALSE, col.names = FALSE, quote = FALSE)
write.table(unique_old, "unique_old.txt", row.names = FALSE, col.names = FALSE, quote = FALSE)
write.table(unique_new, "unique_new.txt", row.names = FALSE, col.names = FALSE, quote = FALSE)
# Relative to old
perc_overlap_old <- length(overlap_ids) / length(core_goids_old) * 100
perc_overlap_old
# Relative to new
perc_overlap_new <- length(overlap_ids) / length(core_goids_new) * 100
perc_overlap_new
# Relative to union
perc_overlap_union <- length(overlap_ids) / length(union(core_goids_old, core_goids_new)) * 100
perc_overlap_union
# Counts
count_old <- length(core_goids_old)
count_new <- length(core_goids_new)
count_overlap <- length(overlap_ids)
count_unique_old <- length(unique_old)
count_unique_new <- length(unique_new)
# Percentages
perc_overlap_old <- round(count_overlap / count_old * 100, 2)
perc_overlap_new <- round(count_overlap / count_new * 100, 2)
perc_overlap_union <- round(count_overlap / length(union(core_goids_old, core_goids_new)) * 100, 2)
# Summary tcoree
summary_tcoree <- data.frame(
Category = c("Old total", "New total", "Overlap", "Unique to old", "Unique to new"),
Count = c(count_old, count_new, count_overlap, count_unique_old, count_unique_new),
Percent = c(100, 100, perc_overlap_union, 100 - perc_overlap_old, 100 - perc_overlap_new)
)
print(summary_tcoree)
write.csv(summary_tcoree, "GO_BP_overlap_summary.csv", row.names = FALSE)
